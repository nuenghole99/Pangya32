<!DOCTYPE html>

<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ปังย่า บ้าน32</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@400;500;600;700&family=Sarabun:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode-generator/1.4.4/qrcode.min.js"></script>
<style>
:root{--brand:#FF5A1F;--brand-dark:#E0440E;--brand-soft:#FFF1EA;--go:#13B36A;--ink:#1A1614;--muted:#8A817C;--line:#EEE7E2;--surface:#FFFFFF;--bg:#FAF7F4;--shadow:0 6px 24px rgba(26,22,20,.10)}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--ink);max-width:480px;margin:0 auto;min-height:100vh}
h1,h2,h3,.brandfont{font-family:'Prompt',sans-serif}
.hero{background:linear-gradient(135deg,var(--brand) 0%,var(--brand-dark) 100%);color:#fff;padding:22px 20px 26px;position:relative;overflow:hidden}
.hero::after{content:"";position:absolute;right:-30px;top:-30px;width:160px;height:160px;background:rgba(255,255,255,.10);border-radius:50%}
.hero h1{font-size:26px;font-weight:700;line-height:1.15}
.hero p{font-size:14px;opacity:.92;margin-top:5px}
.hero .open{display:flex;align-items:center;gap:6px;margin-top:14px;font-size:13px;background:rgba(0,0,0,.15);width:fit-content;padding:6px 12px;border-radius:999px}
.dot{width:8px;height:8px;border-radius:50%;background:#7CFFB2;box-shadow:0 0 0 3px rgba(124,255,178,.3)}
.menu-wrap{padding:18px 16px 130px}
.section-title{font-family:'Prompt';font-weight:600;font-size:18px;margin:6px 4px 14px;display:flex;align-items:center;gap:8px}
.section-title .bar{width:4px;height:18px;background:var(--brand);border-radius:4px}
.card{background:var(--surface);border-radius:18px;box-shadow:var(--shadow);display:flex;gap:12px;padding:12px;margin-bottom:14px}
.thumb{width:96px;height:96px;border-radius:14px;flex-shrink:0;overflow:hidden;background:linear-gradient(135deg,#FFE3D2,#FFD0B5);display:flex;align-items:center;justify-content:center;font-size:40px;position:relative}
.thumb img{width:100%;height:100%;object-fit:cover}
.tag{position:absolute;top:8px;left:8px;background:var(--brand);color:#fff;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;font-family:'Prompt';z-index:2}
.info{flex:1;min-width:0;display:flex;flex-direction:column}
.info .name{font-family:'Prompt';font-weight:600;font-size:16px;line-height:1.2}
.info .desc{font-size:12.5px;color:var(--muted);margin-top:3px;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.info .bottom{margin-top:auto;display:flex;align-items:center;justify-content:space-between;padding-top:8px}
.price{font-family:'Prompt';font-weight:700;font-size:17px;color:var(--brand-dark)}
.add-btn{background:var(--brand);color:#fff;border:none;font-family:'Prompt';font-weight:600;font-size:14px;padding:8px 16px;border-radius:999px;cursor:pointer;box-shadow:0 3px 10px rgba(255,90,31,.35)}
.qty{display:flex;align-items:center;gap:10px;background:var(--brand-soft);border-radius:999px;padding:3px}
.qty button{width:30px;height:30px;border:none;border-radius:50%;background:var(--brand);color:#fff;font-size:20px;font-weight:600;cursor:pointer;display:grid;place-items:center}
.qty .n{font-family:'Prompt';font-weight:600;min-width:18px;text-align:center;font-size:16px}
.cartbar{position:fixed;left:50%;transform:translateX(-50%) translateY(120px);bottom:14px;width:calc(100% - 28px);max-width:452px;background:var(--ink);color:#fff;border-radius:16px;padding:13px 16px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 10px 30px rgba(0,0,0,.28);cursor:pointer;opacity:0;transition:transform .28s cubic-bezier(.2,.8,.3,1),opacity .2s;z-index:40}
.cartbar.show{transform:translateX(-50%) translateY(0);opacity:1}
.cartbar .left{display:flex;align-items:center;gap:11px}
.cartbar .cnt{background:#fff;color:var(--ink);font-family:'Prompt';font-weight:700;width:34px;height:34px;border-radius:11px;display:grid;place-items:center;font-size:15px}
.cartbar .lbl{font-size:13px;opacity:.8}
.cartbar .ttl{font-family:'Prompt';font-weight:600;font-size:15px}
.cartbar .go{font-family:'Prompt';font-weight:600;font-size:15px}
.overlay{position:fixed;inset:0;background:rgba(26,22,20,.5);opacity:0;pointer-events:none;transition:opacity .25s;z-index:50}
.overlay.show{opacity:1;pointer-events:auto}
.sheet{position:fixed;left:50%;transform:translateX(-50%) translateY(100%);bottom:0;width:100%;max-width:480px;background:var(--bg);border-radius:22px 22px 0 0;z-index:60;transition:transform .3s cubic-bezier(.2,.8,.3,1);max-height:92vh;display:flex;flex-direction:column}
.sheet.show{transform:translateX(-50%) translateY(0)}
.sheet-head{padding:16px 20px 12px;border-bottom:1px solid var(--line);position:relative}
.sheet-head h2{font-size:19px;font-weight:600}
.grab{width:40px;height:4px;background:var(--line);border-radius:4px;margin:0 auto 12px}
.close-x{position:absolute;right:16px;top:16px;width:30px;height:30px;border:none;background:#fff;border-radius:50%;font-size:18px;cursor:pointer;box-shadow:var(--shadow);color:var(--muted);z-index:3}
.sheet-body{overflow-y:auto;padding:8px 20px;flex:1}
.crow{display:flex;align-items:center;gap:12px;padding:13px 0;border-bottom:1px solid var(--line)}
.crow .cthumb{width:48px;height:48px;border-radius:11px;flex-shrink:0;overflow:hidden;background:linear-gradient(135deg,#FFE3D2,#FFD0B5);display:grid;place-items:center;font-size:22px}
.crow .cthumb img{width:100%;height:100%;object-fit:cover}
.crow .cinfo{flex:1;min-width:0}
.crow .cname{font-family:'Prompt';font-weight:600;font-size:14.5px}
.crow .cunit{font-size:12px;color:var(--muted)}
.crow .cqty{display:flex;align-items:center;gap:9px}
.crow .cqty button{width:27px;height:27px;border:1px solid var(--line);background:#fff;border-radius:50%;font-size:17px;cursor:pointer;color:var(--brand);display:grid;place-items:center}
.crow .cqty .n{font-family:'Prompt';font-weight:600;min-width:16px;text-align:center}
.empty{text-align:center;color:var(--muted);padding:40px 0;font-size:14px}
.field{margin:16px 0 4px}
.field label{font-family:'Prompt';font-weight:500;font-size:14px;display:block;margin-bottom:6px}
.field label .req{color:var(--brand)}
.field input,.field textarea{width:100%;border:1.5px solid var(--line);border-radius:13px;padding:13px 15px;font-family:'Sarabun';font-size:15px;background:#fff;outline:none}
.field textarea{resize:none;height:64px}
.hint{font-size:12px;color:var(--muted);margin-top:5px}
.paylist{display:flex;flex-direction:column;gap:9px}
.payrow{display:flex;align-items:center;gap:12px;background:#fff;border:1.5px solid var(--line);border-radius:13px;padding:12px 14px;cursor:pointer;transition:all .15s}
.payrow.sel{border-color:var(--brand);background:var(--brand-soft)}
.payrow .pemoji{font-size:22px}
.payrow .plabel{flex:1;font-family:'Prompt';font-weight:500;font-size:14.5px}
.payrow .ptick{width:24px;height:24px;border-radius:50%;border:2px solid var(--line);display:grid;place-items:center;color:#fff;font-size:14px}
.payrow.sel .ptick{background:var(--brand);border-color:var(--brand)}
.summary{background:#fff;border-radius:14px;padding:14px 16px;margin-top:16px;box-shadow:var(--shadow)}
.summary .row{display:flex;justify-content:space-between;font-size:14px;padding:3px 0;color:var(--muted)}
.summary .row.total{font-family:'Prompt';font-weight:700;font-size:18px;color:var(--ink);border-top:1px dashed var(--line);margin-top:8px;padding-top:11px}
.sheet-foot{padding:14px 20px calc(16px + env(safe-area-inset-bottom));border-top:1px solid var(--line);background:var(--surface)}
.send-btn{width:100%;background:var(--go);color:#fff;border:none;border-radius:15px;padding:16px;font-family:'Prompt';font-weight:600;font-size:17px;cursor:pointer;box-shadow:0 6px 18px rgba(19,179,106,.35);display:flex;align-items:center;justify-content:center;gap:9px}
.send-btn:disabled{background:#CFC9C4;box-shadow:none}
.pay-screen{position:fixed;inset:0;background:var(--bg);z-index:65;display:none;flex-direction:column;overflow-y:auto;padding:24px 20px 40px}
.pay-screen.show{display:flex}
.paycard{background:#fff;border-radius:22px;box-shadow:var(--shadow);padding:24px 20px;text-align:center;position:relative;margin:auto;width:100%;max-width:360px}
.paycard h2{font-size:20px;font-weight:700;margin-bottom:4px}
.paycard .amount{font-family:'Prompt';font-weight:700;font-size:34px;color:var(--brand-dark);margin:6px 0 16px}
.qrbox{background:#fff;border:2px dashed var(--line);border-radius:16px;padding:14px;display:inline-block;min-width:200px;min-height:200px}
.qrbox img{width:200px;height:200px;display:block}
.qrfallback{font-size:13px;color:var(--muted);padding:30px 10px}
.payto{font-size:13.5px;color:var(--muted);margin-top:12px}
.payto b{color:var(--ink);font-family:'Prompt';font-size:16px;letter-spacing:.5px}
.copybtn{margin-top:8px;background:var(--brand-soft);color:var(--brand-dark);border:1px solid #FFD0B5;border-radius:999px;font-family:'Prompt';font-weight:500;font-size:13px;padding:7px 16px;cursor:pointer}
.payhint{font-size:13px;color:var(--muted);margin:16px 0;line-height:1.5;background:var(--brand-soft);padding:10px;border-radius:10px}
.slipimg{width:100%;max-width:220px;border-radius:12px;margin:0 auto 14px;display:block;border:1px solid var(--line)}
.promptpay-logo{display:inline-block;background:#003D6A;color:#fff;font-family:'Prompt';font-weight:600;font-size:11px;padding:3px 9px;border-radius:6px;letter-spacing:.5px;margin-bottom:12px}
.ghost-btn{width:100%;background:#fff;border:1.5px solid var(--line);color:var(--ink);font-family:'Prompt';font-weight:500;font-size:14.5px;padding:13px;cursor:pointer;margin-top:9px;border-radius:14px}
.done{position:fixed;inset:0;background:var(--bg);z-index:70;display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:30px}
.done.show{display:flex}
.done .ring{width:96px;height:96px;border-radius:50%;background:var(--go);display:grid;place-items:center;font-size:50px;color:#fff;margin-bottom:20px;animation:pop .4s cubic-bezier(.2,1.4,.4,1)}
@keyframes pop{0%{transform:scale(0)}100%{transform:scale(1)}}
.done h2{font-size:23px;font-weight:700;margin-bottom:8px}
.done p{color:var(--muted);font-size:15px;line-height:1.5;max-width:300px}
.done .again{margin-top:26px;background:var(--brand);color:#fff;border:none;border-radius:14px;padding:14px 30px;font-family:'Prompt';font-weight:600;font-size:15px;cursor:pointer}
.toast{position:fixed;left:50%;bottom:90px;transform:translateX(-50%) translateY(20px);background:var(--ink);color:#fff;padding:11px 20px;border-radius:999px;font-size:13.5px;font-family:'Prompt';opacity:0;pointer-events:none;transition:all .25s;z-index:90;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>

<div class="hero">
  <span class="badge brandfont" style="display:inline-block;background:rgba(255,255,255,.20);font-size:12px;padding:4px 11px;border-radius:999px;margin-bottom:10px;font-weight:600">🛵 ส่งถึงหน้าบ้านในหมู่บ้าน</span>
  <h1>ปังย่า บ้าน32</h1>
  <p>อร่อยร้อนๆ สั่งง่ายผ่านมือถือ</p>
  <div class="open"><span class="dot"></span> เปิดรับออเดอร์อยู่</div>
</div>

<div class="menu-wrap">
  <div class="section-title"><span class="bar"></span> เมนูทั้งหมด</div>
  <div id="menuList"></div>
</div>

<div class="cartbar" id="cartBar" onclick="openSheet()">
  <div class="left"><div class="cnt" id="cartCount">0</div>
    <div><div class="lbl">ดูตะกร้าของคุณ</div><div class="ttl" id="cartTotal">฿0</div></div></div>
  <div class="go">สั่งเลย ›</div>
</div>

<div class="overlay" id="overlay" onclick="closeSheet()"></div>
<div class="sheet" id="sheet">
  <div class="sheet-head"><div class="grab"></div><h2>ตะกร้าของฉัน</h2>
    <button class="close-x" onclick="closeSheet()">✕</button></div>
  <div class="sheet-body">
    <div id="cartItems"></div>
    <div class="field"><label>บ้านเลขที่ / จุดส่ง <span class="req">*จำเป็น</span></label>
      <input id="house" type="text" placeholder="เช่น 99/1 ซอย 3"></div>
    <div class="field"><label>ชื่อผู้สั่ง (ไม่ใส่ก็ได้)</label>
      <input id="cname" type="text" placeholder="เช่น คุณเอ"></div>
    <div class="field"><label>วิธีชำระเงิน</label><div id="payList" class="paylist"></div></div>
    <div class="field"><label>หมายเหตุถึงร้าน (ไม่ใส่ก็ได้)</label>
      <textarea id="note" placeholder="เช่น ไม่เผ็ด / ขอช้อนส้อม"></textarea></div>
    <div class="summary">
      <div class="row"><span>ค่าอาหาร</span><span id="sumFood">฿0</span></div>
      <div class="row total"><span>ยอดรวม</span><span id="sumTotal">฿0</span></div></div>
  </div>
  <div class="sheet-foot">
    <button class="send-btn" id="sendBtn" onclick="confirmOrder()"><span>🛎️</span> ถัดไป</button>
  </div>
</div>

<div class="pay-screen" id="payScreen">
  <div class="paycard">
    <button class="close-x" onclick="closePay()">✕</button>
    <div class="promptpay-logo">PromptPay</div>
    <h2>สแกนจ่ายก่อนสั่ง</h2>
    <div class="amount" id="payAmount">฿0</div>
    <div class="qrbox" id="qrBox"></div>
    <div class="payto" id="payTo"></div>
    <button class="copybtn" onclick="copyPP()">📋 คัดลอกเลขพร้อมเพย์</button>
    <p class="payhint">1. สแกน QR หรือคัดลอกเลขไปจ่ายในแอปธนาคาร<br>2. แนบสลิป แล้วกดส่งออเดอร์</p>
    <div id="slipPreview"></div>
    <input type="file" id="slipInput" accept="image/*" capture="environment" style="display:none" onchange="onSlip(event)">
    <button class="ghost-btn" id="slipBtn" onclick="pickSlip()">📎 แนบสลิปการโอน</button>
    <button class="send-btn" style="margin-top:9px" onclick="payConfirm()"><span>✅</span> จ่ายแล้ว ส่งออเดอร์</button>
  </div>
</div>

<div class="done" id="doneScreen">
  <div class="ring">✓</div>
  <h2>ส่งออเดอร์แล้ว!</h2>
  <p id="doneMsg"></p>
  <button class="again" onclick="resetAll()">สั่งเพิ่ม</button>
</div>
<div class="toast" id="toast"></div>

<script>
/* ============================================================
   📝 ส่วนตั้งค่าร้าน — แก้ตรงนี้แล้วใช้ได้เลย
   ============================================================ */
const CONFIG = {
  shopName: "ปังย่า บ้าน32",

  // 👉 ลิงก์ Apps Script (ใส่แล้วเมนูจะดึงจากหลังบ้าน อัปเดตอัตโนมัติ)
  //    ว่าง = ใช้เมนูที่ใส่ด้านล่างแทน
  apiUrl: "",

  // 👉 LINE OA ID ของร้าน
  lineOaId: "",

  // 👉 พร้อมเพย์ร้าน
  promptpayId: "0839617064",
  qrImage: "",  // QR จากแอปธนาคาร (อัปจากหน้า admin)

  // 👉 วิธีจ่าย
  payments: [
    { id:"promptpay", label:"สแกนจ่ายก่อน (พร้อมเพย์)", emoji:"📱", type:"promptpay" },
    { id:"cod",       label:"จ่ายเงินสดตอนรับของ",       emoji:"💵", type:"cod" },
    { id:"p6040",     label:"โครงการ 60/40",              emoji:"🪙", type:"other" }
  ],

  // 👉 เมนู — เพิ่ม/ลบ/แก้ได้เลย (ก๊อปบล็อก { } เพื่อเพิ่ม ใส่ , คั่น)
  menu: [
    { name:"ปังย่าเนยนม", price:35, desc:"ขนมปังย่างเนยสด ราดนมข้น หอมกรุบ", img:"", emoji:"🍞", tag:"ขายดี" },
    { name:"กะเพราไข่ดาว", price:60, desc:"กะเพราหมูสับร้อนๆ ราดข้าวสวย ไข่ดาวกรอบ", img:"", emoji:"🍳", tag:"" },
    { name:"ชาเย็น",     price:25, desc:"ชาไทยเข้มข้น หวานมัน เย็นชื่นใจ",   img:"", emoji:"🧋", tag:"" }
  ]
};
/* ====================== จบส่วนตั้งค่า ====================== */

const cart={};
let payMethod=CONFIG.payments[0].id;
let pendingSlip=null, lastOrder=null;

function baht(n){return "฿"+Number(n).toLocaleString('th-TH');}
function thumbInner(m){return m.img?`<img src="${m.img}" alt="${m.name}" onerror="this.style.display='none';this.parentNode.insertAdjacentText('beforeend','${m.emoji||'🍽️'}')">`:(m.emoji||"🍽️");}

function renderMenu(){
  const w=document.getElementById('menuList');
  if(!CONFIG.menu.length){w.innerHTML='<div class="empty">ยังไม่มีเมนู</div>';return;}
  w.innerHTML=CONFIG.menu.map((m,i)=>{
    const q=cart[i]||0;
    const ctrl=q>0?`<div class="qty"><button onclick="dec(${i})">−</button><span class="n">${q}</span><button onclick="inc(${i})">+</button></div>`:`<button class="add-btn" onclick="inc(${i})">+ เพิ่ม</button>`;
    const tag=m.tag?`<span class="tag">${m.tag}</span>`:"";
    return `<div class="card"><div class="thumb">${tag}${thumbInner(m)}</div><div class="info"><div class="name">${m.name}</div><div class="desc">${m.desc||''}</div><div class="bottom"><div class="price">${baht(m.price)}</div><div>${ctrl}</div></div></div></div>`;
  }).join('');
}
function inc(i){cart[i]=(cart[i]||0)+1;refresh();}
function dec(i){if(cart[i]){cart[i]--;if(cart[i]<=0)delete cart[i];}refresh();}
function totals(){let c=0,s=0;for(const i in cart){c+=cart[i];s+=cart[i]*CONFIG.menu[i].price;}return{count:c,sum:s};}
function refresh(){renderMenu();renderCart();renderPayments();const{count,sum}=totals();document.getElementById('cartCount').textContent=count;document.getElementById('cartTotal').textContent=baht(sum);document.getElementById('cartBar').classList.toggle('show',count>0);}
function renderCart(){const box=document.getElementById('cartItems');const keys=Object.keys(cart);
  if(!keys.length)box.innerHTML='<div class="empty">ยังไม่มีรายการ<br>เลือกเมนูที่อยากกินได้เลย 😋</div>';
  else box.innerHTML=keys.map(i=>{const m=CONFIG.menu[i],q=cart[i];return `<div class="crow"><div class="cthumb">${thumbInner(m)}</div><div class="cinfo"><div class="cname">${m.name}</div><div class="cunit">${baht(m.price)} × ${q} = ${baht(m.price*q)}</div></div><div class="cqty"><button onclick="dec(${i})">−</button><span class="n">${q}</span><button onclick="inc(${i})">+</button></div></div>`;}).join('');
  const{sum}=totals();document.getElementById('sumFood').textContent=baht(sum);document.getElementById('sumTotal').textContent=baht(sum);document.getElementById('sendBtn').disabled=!keys.length;}
function renderPayments(){document.getElementById('payList').innerHTML=CONFIG.payments.map(p=>`<div class="payrow ${p.id===payMethod?'sel':''}" onclick="selectPay('${p.id}')"><div class="pemoji">${p.emoji||'💳'}</div><div class="plabel">${p.label}</div><div class="ptick">${p.id===payMethod?'✓':''}</div></div>`).join('');}
function selectPay(id){payMethod=id;renderPayments();}
function openSheet(){document.getElementById('overlay').classList.add('show');document.getElementById('sheet').classList.add('show');}
function closeSheet(){document.getElementById('overlay').classList.remove('show');document.getElementById('sheet').classList.remove('show');}
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2200);}
function payLabel(){return (CONFIG.payments.find(x=>x.id===payMethod)||{}).label||"";}

function buildOrderText(o){
  let L=[];
  L.push("🛎️ ออเดอร์ใหม่ — "+CONFIG.shopName);
  L.push("🏠 บ้าน: "+o.house);
  if(o.name)L.push("👤 "+o.name);
  L.push("————————————");
  for(const i in cart)L.push("• "+CONFIG.menu[i].name+" ×"+cart[i]+" "+baht(CONFIG.menu[i].price*cart[i]));
  L.push("————————————");
  L.push("💰 รวม "+baht(o.total));
  L.push("💳 "+o.pay);
  if(o.note)L.push("📝 "+o.note);
  return L.join("\n");
}

/* ---- ส่งเข้า LINE ---- */
function sendToLine(text){
  const oa=CONFIG.lineOaId;
  if(oa){
    // ✅ LINE เปิดตรงแชทร้าน ข้อความพร้อม ลูกค้าแตะ "ส่ง" ทีเดียวจบ
    const id=oa.replace(/^@/,'');
    window.location.href="https://line.me/R/oaMessage/%40"+encodeURIComponent(id)+"/?"+encodeURIComponent(text);
  }else{
    // สำรอง: เปิดหน้าแชร์ให้เลือกแชท
    window.open("https://line.me/R/share?text="+encodeURIComponent(text),"_blank");
  }
}

function confirmOrder(){
  const house=document.getElementById('house').value.trim();
  const name=document.getElementById('cname').value.trim();
  const note=document.getElementById('note').value.trim();
  if(!Object.keys(cart).length){toast("ยังไม่มีรายการในตะกร้า");return;}
  if(!house){toast("กรุณากรอกบ้านเลขที่ก่อนนะครับ");document.getElementById('house').focus();return;}
  const{sum,count}=totals();
  lastOrder={house,name,note,total:sum,count,pay:payLabel(),items:Object.keys(cart).map(i=>CONFIG.menu[i].name+" x"+cart[i]).join(", ")};
  lastOrder.text=buildOrderText(lastOrder);
  closeSheet();
  const p=CONFIG.payments.find(x=>x.id===payMethod);
  if(p&&p.type==='promptpay'&&CONFIG.promptpayId){openPay(sum);}
  else{sendToLine(lastOrder.text);showDone("กดส่งข้อความใน LINE ให้ร้านด้วยนะครับ ร้านจะทำให้ทันที 🧑‍🍳");}
}

/* ---- PromptPay QR ---- */
function ppField(id,v){return id+String(v.length).padStart(2,'0')+v;}
function ppCRC(s){let c=0xFFFF;for(let i=0;i<s.length;i++){c^=s.charCodeAt(i)<<8;for(let j=0;j<8;j++){c=(c&0x8000)?((c<<1)^0x1021):(c<<1);c&=0xFFFF;}}return c.toString(16).toUpperCase().padStart(4,'0');}
function ppPayload(t,a){const id=(t||"").replace(/[^0-9]/g,'');const m=a?'12':'11';let acc;if(id.length>=15)acc=ppField('03',id);else if(id.length>=13)acc=ppField('02',id);else{const ph=('0000000000000'+id.replace(/^0/,'66')).slice(-13);acc=ppField('01',ph);}const mc=ppField('29',ppField('00','A000000677010111')+acc);let p=ppField('00','01')+ppField('01',m)+mc+ppField('53','764');if(a)p+=ppField('54',Number(a).toFixed(2));p+=ppField('58','TH')+'6304';return p+ppCRC(p);}

function openPay(amount){
  document.getElementById('payAmount').textContent=baht(amount);
  document.getElementById('payTo').innerHTML="พร้อมเพย์<br><b>"+CONFIG.promptpayId+"</b><br>"+CONFIG.shopName;
  const box=document.getElementById('qrBox');
  if(CONFIG.qrImage){
    box.innerHTML='<img src="'+CONFIG.qrImage+'" style="width:200px;height:200px;object-fit:contain;border-radius:8px">';
  }else{
    try{const qr=qrcode(0,'M');qr.addData(ppPayload(CONFIG.promptpayId,amount));qr.make();box.innerHTML=qr.createImgTag(5,8);const img=box.querySelector('img');if(img){img.style.width='200px';img.style.height='200px';}}
    catch(e){box.innerHTML='<div class="qrfallback">โอนพร้อมเพย์<br><b>'+CONFIG.promptpayId+'</b><br>ยอด '+baht(amount)+'</div>';}
  }
  document.getElementById('slipPreview').innerHTML="";pendingSlip=null;
  document.getElementById('slipBtn').innerHTML='📎 แนบสลิปการโอน';
  document.getElementById('payScreen').classList.add('show');
}
function closePay(){document.getElementById('payScreen').classList.remove('show');}
function copyPP(){const n=CONFIG.promptpayId;if(navigator.clipboard&&navigator.clipboard.writeText)navigator.clipboard.writeText(n).then(()=>toast('คัดลอกแล้ว ✓')).catch(()=>fbCopy(n));else fbCopy(n);}
function fbCopy(n){const t=document.createElement('textarea');t.value=n;document.body.appendChild(t);t.select();try{document.execCommand('copy');toast('คัดลอกแล้ว ✓');}catch(e){}document.body.removeChild(t);}

function pickSlip(){document.getElementById('slipInput').click();}
function downscale(file,maxW,cb){const r=new FileReader();r.onload=e=>{const img=new Image();img.onload=()=>{const sc=Math.min(1,maxW/img.width),w=Math.round(img.width*sc),h=Math.round(img.height*sc);const c=document.createElement('canvas');c.width=w;c.height=h;c.getContext('2d').drawImage(img,0,0,w,h);cb(c.toDataURL('image/jpeg',0.7));};img.src=e.target.result;};r.readAsDataURL(file);}
function onSlip(e){const f=e.target.files[0];if(!f)return;downscale(f,1000,d=>{pendingSlip=d;document.getElementById('slipPreview').innerHTML='<img class="slipimg" src="'+d+'">';document.getElementById('slipBtn').innerHTML='✅ แนบสลิปแล้ว (แตะเพื่อเปลี่ยน)';});}

function payConfirm(){
  // ส่งออเดอร์ + สลิป (ถ้ามี) เข้า LINE ร้าน
  let text=lastOrder.text;
  if(pendingSlip) text+="\n🧾 (มีสลิปแนบมาด้วย)";
  sendToLine(text);
  closePay();
  showDone("กดส่งข้อความใน LINE ให้ร้านด้วยนะครับ ร้านจะทำให้ทันที 🧑‍🍳");
}

function showDone(msg){document.getElementById('doneMsg').textContent=msg;document.getElementById('doneScreen').classList.add('show');}
function resetAll(){for(const k in cart)delete cart[k];document.getElementById('house').value="";document.getElementById('cname').value="";document.getElementById('note').value="";payMethod=CONFIG.payments[0].id;pendingSlip=null;lastOrder=null;document.getElementById('doneScreen').classList.remove('show');refresh();}

/* ---- โหลดเมนู + ตั้งค่าจากหลังบ้าน ---- */
function loadMenu(){
  if(!CONFIG.apiUrl){refresh();return;}
  const cb='_lm'+Date.now();
  window[cb]=function(data){
    delete window[cb];
    if(data.menu&&Array.isArray(data.menu)&&data.menu.length) CONFIG.menu=data.menu;
    if(data.settings){
      if(data.settings.promptpayId) CONFIG.promptpayId=data.settings.promptpayId;
      if(data.settings.qrImage!==undefined) CONFIG.qrImage=data.settings.qrImage;
    }
    refresh();
  };
  const s=document.createElement('script');
  s.src=CONFIG.apiUrl+(CONFIG.apiUrl.includes('?')?'&':'?')+'callback='+cb+'&t='+Date.now();
  s.onerror=function(){delete window[cb];refresh();};
  document.head.appendChild(s);
}
loadMenu();
</script>

